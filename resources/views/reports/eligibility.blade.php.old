    <!-- Risk Factors -->
    @if($assessment->risk_factors)
        <div class="section">
            <h3 class="section-title">Risk Factors</h3>
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Risk Factor</th>
                        <th style="text-align: center;">Score</th>
                        <th style="text-align: center;">Weight</th>
                        <th style="text-align: center;">Status</th>
                    </tr>
                </thead>
                <tbody>
                    @php
                        $riskFactors = is_array($assessment->risk_factors) 
                            ? $assessment->risk_factors 
                            : ($assessment->risk_factors ? json_decode($assessment->risk_factors, true) : []);
                    @endphp
                    @foreach($riskFactors ?? [] as $riskItem)
                    <tr>
                        @php
                            // Extract factor details from the risk item
                            if (is_array($riskItem)) {
                                $factorName = $riskItem['factor'] ?? 'Unknown';
                                $factorValue = $riskItem['value'] ?? 0;
                                $factorWeight = $riskItem['weight'] ?? 0;
                            } else {
                                $factorName = 'Unknown';
                                $factorValue = 0;
                                $factorWeight = 0;
                            }
                            
                            // Format factor name to human-readable
                            $displayName = ucwords(str_replace('_', ' ', $factorName));
                            $displayValue = is_numeric($factorValue) ? number_format($factorValue, 2) : $factorValue;
                        @endphp
                        <td>{{ $displayName }}</td>
                        <td style="text-align: center;">{{ $displayValue }}</td>
                        <td style="text-align: center;">{{ $factorWeight }}%</td>
                        <td style="text-align: center;">
                            @if(is_numeric($factorValue) && $factorValue < 40)
                            <span class="status-badge success">Low Risk</span>
                            @elseif(is_numeric($factorValue) && $factorValue < 70)
                            <span class="status-badge warning">Medium Risk</span>
                            @elseif(is_numeric($factorValue))
                            <span class="status-badge danger">High Risk</span>
                            @else
                            <span class="status-badge">-</span>
                            @endif
                        </td>
                    </tr>
                    @endforeach
                </tbody>
            </table>
        </div>
    @endif

    <!-- Income & Debt Breakdown -->
    <div class="section">
        <h3 class="section-title">Income & Debt Breakdown</h3>
        @php
            $grossIncome = is_numeric($assessment->gross_monthly_income) ? $assessment->gross_monthly_income : 0;
            $netIncome = is_numeric($assessment->net_monthly_income) ? $assessment->net_monthly_income : 0;
            $totalDebt = is_numeric($assessment->total_monthly_debt) ? $assessment->total_monthly_debt : 0;
            $requestedInstallment = is_numeric($assessment->requested_monthly_installment) ? $assessment->requested_monthly_installment : 0;
            $debtCount = $assessment->detected_debt_count ?? 0;
            $debtCount = is_array($debtCount) ? 0 : $debtCount;
            $customerTypeLabel = $customer->customer_type ? $customer->customer_type->label() : 'N/A';
            $customerTypeLabel = is_array($customerTypeLabel) ? (isset($customerTypeLabel[0]) ? $customerTypeLabel[0] : 'N/A') : $customerTypeLabel;
        @endphp
        <table class="data-table">
            <thead>
                <tr>
                    <th>Category</th>
                    <th style="text-align: right;">Monthly Amount (TZS)</th>
                    <th style="text-align: center;">Details</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td><strong>Gross Monthly Income</strong></td>
                    <td style="text-align: right;"><strong>{{ number_format($grossIncome, 2) }}</strong></td>
                    <td style="text-align: center;">{{ $customerTypeLabel }}</td>
                </tr>
                <tr>
                    <td>Less: Deductions/Expenses</td>
                    <td style="text-align: right;">{{ number_format($grossIncome - $netIncome, 2) }}</td>
                    <td style="text-align: center;">Tax, NSSF, etc.</td>
                </tr>
                <tr>
                    <td><strong>Net Monthly Income</strong></td>
                    <td style="text-align: right;"><strong>{{ number_format($netIncome, 2) }}</strong></td>
                    <td style="text-align: center;">Available for debt servicing</td>
                </tr>
                <tr>
                    <td colspan="3" style="border-bottom: none;">&nbsp;</td>
                </tr>
                <tr>
                    <td><strong>Existing Debt Obligations</strong></td>
                    <td style="text-align: right;"><strong>{{ number_format($totalDebt, 2) }}</strong></td>
                    <td style="text-align: center;">{{ $debtCount }} debts detected</td>
                </tr>
                <tr>
                    <td><strong>Proposed Loan Installment</strong></td>
                    <td style="text-align: right;"><strong>{{ number_format($requestedInstallment, 2) }}</strong></td>
                    <td style="text-align: center;">Based on requested amount</td>
                </tr>
                <tr>
                    <td><strong>Total Monthly Obligations</strong></td>
                    <td style="text-align: right;"><strong>{{ number_format($totalDebt + $requestedInstallment, 2) }}</strong></td>
                    <td style="text-align: center;">Existing + Proposed</td>
                </tr>
                <tr>
                    <td colspan="3" style="border-bottom: none;">&nbsp;</td>
                </tr>
                <tr>
                    <td><strong>Net Disposable Income</strong></td>
                    <td style="text-align: right;"><strong>{{ number_format($netIncome - $totalDebt - $requestedInstallment, 2) }}</strong></td>
                    <td style="text-align: center;">After all obligations</td>
                </tr>
            </tbody>
        </table>
    </div>

    <!-- Conditions -->
    @php
        $conditions = is_array($assessment->conditions) 
            ? $assessment->conditions 
            : ($assessment->conditions ? json_decode($assessment->conditions, true) : []);
    @endphp
    @if($conditions && count($conditions) > 0)
        <div class="conditions">
            <div style="font-weight: 800; margin-bottom: 5px;">Conditions & Requirements</div>
            <ul>
                @foreach($conditions as $condition)
                @php
                    $conditionText = is_array($condition) ? implode(': ', $condition) : $condition;
                @endphp
                <li>{{ $conditionText }}</li>
                @endforeach
            </ul>
        </div>
    @endif

    <!-- Assessment Metadata -->
    <div class="section">
        <h3 class="section-title">Assessment Details</h3>
        @php
            $assessorName = 'System';
            if ($assessment->assessor) {
                if (is_object($assessment->assessor) && isset($assessment->assessor->name)) {
                    $assessorName = $assessment->assessor->name;
                } elseif (is_array($assessment->assessor) && isset($assessment->assessor['name'])) {
                    $assessorName = $assessment->assessor['name'];
                } elseif (is_string($assessment->assessor)) {
                    $assessorName = $assessment->assessor;
                }
            }
            $assessorName = is_array($assessorName) ? (isset($assessorName[0]) ? $assessorName[0] : 'System') : $assessorName;
            $version = $assessment->assessment_version ?? $assessment->version ?? '1.0';
            $version = is_array($version) ? implode('.', $version) : $version;
            $dataSource = $assessment->data_source ?? 'Bank Statement Analysis';
            $dataSource = is_array($dataSource) ? implode(', ', $dataSource) : $dataSource;
        @endphp
        <table class="table">
            <tr>
                <td>Assessment Date</td>
                <td>{{ $assessment->created_at->format('d M Y, H:i') }}</td>
            </tr>
            <tr>
                <td>Assessed By</td>
                <td>{{ $assessorName }}</td>
            </tr>
            <tr>
                <td>Assessment Version</td>
                <td>{{ $version }}</td>
            </tr>
            <tr>
                <td>Data Source</td>
                <td>{{ $dataSource }}</td>
            </tr>
        </table>
    </div>

    <!-- Footer -->
    <div class="footer">
        @php
            $institutionName = $institution->name ?? 'N/A';
            $institutionName = is_array($institutionName) ? (isset($institutionName[0]) ? $institutionName[0] : 'N/A') : $institutionName;
            $footerAppNumber = $application->application_number ?? 'APP';
            $footerAppNumber = is_array($footerAppNumber) ? implode('-', $footerAppNumber) : $footerAppNumber;
        @endphp
        <p><strong>{{ $institutionName }}</strong></p>
        <p>This is a computer-generated document. Report Reference: {{ $footerAppNumber }}_ELG_{{ $generated_at->format('YmdHis') }}</p>
    </div>
    </div>
