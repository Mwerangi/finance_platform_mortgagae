                @if($assessment->monthly_surplus)
                <tr class="highlight">
                    <td><strong>Monthly Surplus</strong></td>
                    <td>Available for loan repayment</td>
                    <td class="text-right"><strong>{{ number_format($assessment->monthly_surplus, 0) }}</strong></td>
                </tr>
                @endif
            </tbody>
        </table>
    </div>
