    <!-- Conditions -->
    @if($assessment->system_decision === 'conditional' && $assessment->conditions)
    <div class="section">
        <div class="section-title">Conditions</div>
        <div class="conditions">
            <div class="conditions-title">The following conditions must be met:</div>
            <ul>
                @php 
                    $conditions = is_string($assessment->conditions) ? json_decode($assessment->conditions, true) : $assessment->conditions;
                @endphp
                @foreach($conditions as $condition)
                    <li>{{ is_array($condition) ? ($condition['description'] ?? $condition['condition'] ?? 'N/A') : $condition }}</li>
                @endforeach
            </ul>
        </div>
    </div>
    @endif

    <!-- Footer -->
    <div class="footer">
        <div class="footer-brand">{{ $institution->name ?? 'Financial Institution' }}</div>
        <div>This automated pre-qualification report is valid for 30 days. Final approval subject to full application review and verification.</div>
        <div style="margin-top: 6px; color: #94a3b8;">Report #{{ $assessment->id }} • Generated {{ $generated_at->format('d M Y, H:i:s') }}</div>
    </div>
</body>
</html>
